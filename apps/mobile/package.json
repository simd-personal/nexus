{
  "name": "upperdeck-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "env": "cd ../.. && npm run mobile:env",
    "mobile:env": "npm run env",
    "eas:env": "cd ../.. && npm run mobile:eas:env",
    "mobile:eas:env": "npm run eas:env",
    "dev": "npm run env && expo start",
    "start": "expo start",
    "ios": "expo run:ios",
    "ios:rebuild": "expo prebuild --platform ios --clean && expo run:ios",
    "android": "expo run:android",
    "build:preview": "npm run eas:env && npx eas-cli build --profile preview",
    "build:preview:ios": "npm run eas:env && npx eas-cli build --profile preview --platform ios",
    "build:preview:android": "npm run eas:env && npx eas-cli build --profile preview --platform android",
    "build:preview:ios:only": "npx eas-cli build --profile preview --platform ios",
    "device:register": "npx eas-cli device:create",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo/vector-icons": "~14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/native": "^7.0.14",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/query-async-storage-persister": "^5.101.2",
    "@tanstack/react-query": "^5.62.8",
    "@tanstack/react-query-persist-client": "^5.101.2",
    "@upperdeck/shared": "file:../../packages/shared",
    "expo": "~52.0.23",
    "expo-asset": "~11.0.5",
    "expo-clipboard": "~7.0.1",
    "expo-constants": "~17.0.4",
    "expo-document-picker": "~13.0.3",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.4",
    "expo-image-manipulator": "~13.0.6",
    "expo-image-picker": "~16.0.4",
    "expo-linear-gradient": "~14.0.2",
    "expo-linking": "~7.0.4",
    "expo-local-authentication": "~14.0.1",
    "expo-router": "~4.0.16",
    "expo-secure-store": "~14.0.1",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.1",
    "expo-updates": "~0.27.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.6",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "eas-cli": "^16.32.0",
    "typescript": "^5.3.3"
  }
}
