{
  "expo": {
    "name": "UpperDeck",
    "slug": "upperdeck",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "upperdeck",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-blank.png",
      "resizeMode": "cover",
      "backgroundColor": "#0B1220"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.upperdeck.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "UpperDeck uses Face ID for quick, secure sign-in."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1220"
      },
      "package": "dev.upperdeck.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPods": [
              { "name": "AppCheckCore", "version": "11.2.0" },
              { "name": "GoogleUtilities/Environment", "modular_headers": true },
              { "name": "GoogleUtilities/UserDefaults", "modular_headers": true },
              { "name": "RecaptchaInterop", "modular_headers": true }
            ]
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B1220",
          "image": "./assets/splash-blank.png",
          "resizeMode": "cover",
          "enableFullScreenImage_legacy": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "UpperDeck needs photo access to upload project pictures for Sunny.",
          "cameraPermission": "UpperDeck needs camera access to capture project photos."
        }
      ],
      "expo-asset",
      "expo-font",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "UpperDeck uses Face ID for quick, secure sign-in."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "3704c57c-2034-4c8c-87cb-046327c304c3"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3704c57c-2034-4c8c-87cb-046327c304c3"
    }
  }
}
