# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=briefnexus-files

# Auth email links (signup confirm, password reset).
# Local dev: set to http://localhost:3000
# On Vercel, runtime VERCEL_URL / VERCEL_PROJECT_PRODUCTION_URL is used automatically
# (so localhost here does not leak into production confirmation emails).
# Production: https://upperdeck.dev
# AUTH_SITE_URL=https://upperdeck.dev
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI (transcription, embeddings, extraction, chat, critical item detection)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic (playbooks, executive memos, strategy documents)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Stripe (Pro checkout + billing portal)
# Test mode locally; use sk_live_… + STRIPE_LIVE_MODE=1 before production launch.
# Run npm run stripe:setup to create products/prices, then npm run verify-stripe-live.
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
STRIPE_PRICE_PRO_MONTHLY=price_your_monthly_price_id
STRIPE_PRICE_PRO_ANNUAL=price_your_annual_price_id
# STRIPE_LIVE_MODE=1

# Transactional email (welcome email on signup)
# RESEND_API_KEY=re_your_resend_key
# RESEND_FROM_EMAIL=Sunny <hello@yourdomain.com>

# Inbound email webhook (Resend/SendGrid → /api/inbound/email)
# Required in production — dev allows unauthenticated calls when unset.
# INBOUND_EMAIL_WEBHOOK_SECRET=your-long-random-secret

# Mobile app (Expo) — auto-synced from web env via npm run mobile:env
# EXPO_PUBLIC_SUPABASE_URL=<same as NEXT_PUBLIC_SUPABASE_URL>
# EXPO_PUBLIC_SUPABASE_ANON_KEY=<same as NEXT_PUBLIC_SUPABASE_ANON_KEY>
# EXPO_PUBLIC_API_URL=https://your-production-url.com
# For EAS preview builds: set NEXT_PUBLIC_SITE_URL to production, then npm run mobile:eas:env
